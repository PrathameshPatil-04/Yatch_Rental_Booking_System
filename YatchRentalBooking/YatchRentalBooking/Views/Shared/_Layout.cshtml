<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Yacht Rental System</title>

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <!-- AdminLTE -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- AOS Animation -->
    <link href="https://unpkg.com/aos@2.3.4/dist/aos.css" rel="stylesheet">

    <style>
        /* Loader */
        #loader {
            position: fixed;
            width: 100%;
            height: 100%;
            background: white;
            z-index: 9999;
        }

        .spinner {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 50px;
            height: 50px;
            border: 5px solid gray;
            border-top: 5px solid blue;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @@keyframes spin {
            100%

        {
            transform: rotate(360deg);
        }

        }

        /* Card Hover */
        .card:hover {
            transform: scale(1.05);
            transition: 0.3s;
        }

        body {
            margin: 0;
            padding: 0;
        }
    </style>
</head>

<body class="hold-transition sidebar-mini">

    <!-- 🔄 Loader -->
    <div id="loader">
        <div class="spinner"></div>
    </div>

    <div class="wrapper">

        <!-- 🔝 Navbar -->
        <nav class="main-header navbar navbar-expand navbar-white navbar-light">

            <span class="navbar-brand fw-bold">🚤 Yacht Rental</span>

            <ul class="navbar-nav ms-auto">
                @if (Context.Session.GetString("UserEmail") != null)
                {
                    <li class="nav-item me-3">
                        👤 @Context.Session.GetString("UserName")
                    </li>
                }
            </ul>

        </nav>

        <!-- 📂 Sidebar (ONLY AFTER LOGIN) -->
        @if (Context.Session.GetString("UserEmail") != null)
        {
            var role = Context.Session.GetString("UserRole");

            <aside class="main-sidebar sidebar-dark-primary elevation-4">

                <a class="brand-link text-center">
                    <span class="brand-text fw-bold">Yacht System</span>
                </a>

                <div class="sidebar">
                    <nav>
                        <ul class="nav nav-pills nav-sidebar flex-column">

                            <!-- USER -->
                            @if (role == "User")
                            {
                                <li class="nav-item">
                                    <a href="/Boat/Index" class="nav-link">
                                        <i class="nav-icon fas fa-ship"></i>
                                        <p>View Boats</p>
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a href="/Booking/History" class="nav-link">
                                        <p>My Bookings</p>
                                    </a>
                                </li>
                            }

                            <!-- OWNER -->
                            @if (role == "Owner")
                            {
                                <li class="nav-item">
                                    <a href="/Owner/Dashboard" class="nav-link">
                                        <p>Dashboard</p>
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a href="/Boat/Create" class="nav-link">
                                        <p>Add Boat</p>
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a href="/Booking/History" class="nav-link">
                                        <p>Bookings</p>
                                    </a>
                                </li>
                            }

                            <!-- ADMIN -->
                            @if (role == "Admin")
                            {
                                <li class="nav-item">
                                    <a href="/Admin/Dashboard" class="nav-link">
                                        <p>Dashboard</p>
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a href="/Boat/Index" class="nav-link">
                                        <p>Manage Boats</p>
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a href="/Booking/History" class="nav-link">
                                        <p>All Bookings</p>
                                    </a>
                                </li>
                            }

                            <!-- LOGOUT -->
                            <li class="nav-item">
                                <a href="/Account/Logout" class="nav-link text-danger">
                                    <p>Logout</p>
                                </a>
                            </li>

                        </ul>
                    </nav>
                </div>

            </aside>
        }

        <!-- 📄 MAIN CONTENT -->
        <div class="content-wrapper p-3">

            <div data-aos="fade-up">
                @RenderBody()
            </div>

        </div>

    </div>

    <!-- 🔔 Toast -->
    <div class="toast-container position-fixed top-0 end-0 p-3">
        <div id="toastMsg" class="toast text-white">
            <div class="toast-body" id="toastText"></div>
        </div>
    </div>

    <!-- Scripts -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>

    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>

    <script>
        AOS.init();

        // Loader hide
        window.onload = function () {
            document.getElementById("loader").style.display = "none";
        };

        // Toast function
        function showToast(message, type = "success") {

            var toast = document.getElementById("toastMsg");

            toast.className = "toast text-white " +
                (type == "success" ? "bg-success" : "bg-danger");

            document.getElementById("toastText").innerText = message;

            var bsToast = new bootstrap.Toast(toast);
            bsToast.show();
        }
    </script>

    <!-- TempData Toast -->
    @if (TempData["Success"] != null)
    {
        <script>
            showToast("@TempData["Success"]");
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <script>
            showToast("@TempData["Error"]", "error");
        </script>
    }

</body>
</html>