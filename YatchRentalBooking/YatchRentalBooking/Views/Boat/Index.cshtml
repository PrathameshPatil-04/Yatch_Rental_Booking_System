<div class="row">

    @foreach (var b in Model)
    {
        <div class="col-md-4" data-aos="zoom-in">
            <div class="card shadow mb-3">

                <img src="@b.ImagePath" class="card-img-top" height="200" />

                <div class="card-body">
                    <h5>@b.Name</h5>
                    <p>@b.Type</p>
                    <p class="text-success">₹@b.PricePerHour</p>

                    <a href="/Booking/Create?boatId=@b.Id"
                       class="btn btn-primary w-100">
                        Book Now
                    </a>
                </div>

            </div>
        </div>
    }
</div>